# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=nexd
DB_PASSWORD=nexd
DB_NAME=nexd
DB_SSLMODE=disable

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# JWT
JWT_SECRET=change-me-in-production

# AI Provider
AI_PROVIDER=openai
AI_HOST=https://api.openai.com/v1
AI_API_KEY=your-openai-api-key
AI_EMBEDDING_MODEL=text-embedding-ada-002
AI_CHAT_MODEL=gpt-4

# Admin
ADMIN_EMAILS=admin@example.com

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Indexing
INDEXING_WORKERS=5
INDEXING_BATCH_SIZE=10
